# Mercado Pago - Access Token (credencial privada, solo en servidor)
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app
VITE_MP_ACCESS_TOKEN=APP_USR-xxxx

# URL del servidor API (para crear preferencias de pago)
# En desarrollo: npm run server -> http://localhost:3001
VITE_API_URL=http://localhost:3001
